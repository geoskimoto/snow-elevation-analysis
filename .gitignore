venv/
__pycache__/
*.pyc
.pytest_cache/
# Ignore runtime caches, but ship the aligned DEM — it's a stable 11 MB
# artifact that lets deploys skip the 250 MB SRTM download entirely.
data/cache/*
!data/cache/dem/
data/cache/dem/*
!data/cache/dem/columbia_basin_swe_aligned.tif
# Ship the timeseries snapshots too — the Trends tab reads the current WY and
# the Historical tab reads the full WY* set (all ~1 MB). Refresh with:
#   git add -f data/cache/timeseries/ && git commit && git push
!data/cache/timeseries/
output/
*.egg-info/
.env
logs/
*.bak
